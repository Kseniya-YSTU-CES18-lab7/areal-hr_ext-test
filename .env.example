# .env.example — ШАБЛОН .env (можно закоммить!)

# Environment
NODE_ENV=development

# Подключение к БД
DB_HOST=127.0.0.1
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=hr_management_db

DB_URL=postgresql://postgres:your_secure_password_here@127.0.0.1:5434/hr_management_db
DATABASE_URL=postgresql://postgres:your_secure_password_here@127.0.0.1:5434/hr_management_db?sslmode=disable

# Параметры для запуска приложения
API_PORT=3000
APP_PORT=8080

SESSION_SECRET=dev-secret-change-in-production