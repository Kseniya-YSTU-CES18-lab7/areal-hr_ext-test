# .env.example — (можно закоммить!)

# === Environment ===
NODE_ENV=production

# === Database ===
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=hr_management_db
DB_HOST=db
DB_PORT=5432

# === Session ===
SESSION_SECRET=change_this_in_production_please_use_long_random_string_32chars+
SESSION_NAME=connect.sid
SESSION_TTL=86400

# === App ===
API_PORT=3000
APP_PORT=8080

# === Optional ===
# DB_HOST=localhost
# DB_PORT=5434
# NODE_ENV=development